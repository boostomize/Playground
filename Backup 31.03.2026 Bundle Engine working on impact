async function initBundleEngine() {
    const config = document.querySelector(".bundle-engine-config");
    if (!config) return;
    const bundleProduct = window.BundleEngineProduct || {};
    const bundleFound = config.dataset.bundleFound === "true";
    if (!bundleFound) {
        console.log("Bundle Engine: No mapping found");
        return;
    }
    const handles = [config.getAttribute("data-product-1-handle"), config.getAttribute("data-product-2-handle")];
    if (!handles[0] || !handles[1]) return;
    const discountType = config.dataset.discountType || "percent";
    const discountValue = parseFloat(config.dataset.discountValue || 0);
    const showBundleProductVariants = config.dataset.showBundleProductVariants === "true";
    const showBundleProductPrice = config.dataset.showBundleProductPrice === "true";
    const afterAddToCart = config.dataset.afterAddToCart || "redirect";
    const form = document.querySelector("form[is='product-form'][action*='/cart/add']") 
          || document.querySelector("form[action*='/cart/add']");
    console.log("Bundle Engine form:", form?.getAttribute("is"), form?.id);
    if (!form) return;
    const oldBundleWrappers = form.querySelectorAll(".bundle-wrapper");
    oldBundleWrappers.forEach((el) => el.remove());
    if (config.dataset.showPriceNote === "true") {
        function insertBundlePriceNote() {
            if (document.querySelector(".bundle-price-note")) return;
            const priceSelectors = [
                ".product-information-price-container",
                ".tee-product-price",
                ".price-list.price-list--lg",
                ".tee-price-wrapper",
                ".price",
                ".product__price",
                ".price__container",
                ".price-item",
                ".price-item--regular",
                "[data-product-price]",
                "[data-price]",
                ".money",
            ];
            let container = null;
            for (const selector of priceSelectors) {
                const el = document.querySelector(selector);
                if (el) {
                    container = el.closest("div") || el;
                    break;
                }
            }
            if (!container) return;
            const note = document.createElement("div");
            note.className = "bundle-price-note";
            note.innerText = config.dataset.priceNoteText;
            note.style.background = config.dataset.priceNoteBg;
            note.style.color = config.dataset.priceNoteTextColor;
            const arrowStyle = document.createElement("style");
            arrowStyle.innerHTML = `.bundle-price-note::after{ border-top:8px solid ${config.dataset.priceNoteBg}; }`;
            document.head.appendChild(arrowStyle);
            container.prepend(note);
        }
        insertBundlePriceNote();
        const observer = new MutationObserver(insertBundlePriceNote);
        observer.observe(document.body, { childList: true, subtree: true });
    }
    const BUNDLE_VARIANTS = Array.isArray(bundleProduct.variants) ? bundleProduct.variants : [];
    const BUNDLE_OPTIONS = Array.isArray(bundleProduct.options) ? bundleProduct.options : [];
    const variantBlock =
        form.querySelector(".product-form__input") ||
        form.querySelector("[class*='variant']") ||
        form.querySelector("fieldset");
    if (variantBlock && !showBundleProductVariants) variantBlock.style.display = "none";

    const bundleWrapper = document.createElement("div");
    bundleWrapper.className = "bundle-wrapper";

    const customTarget = document.querySelector("[data-bundle-variants]");

    if (customTarget) {
        customTarget.innerHTML = "";
        customTarget.appendChild(bundleWrapper);
    } else if (variantBlock) {
        variantBlock.parentNode.insertBefore(bundleWrapper, variantBlock.nextSibling);
    } else {
        form.prepend(bundleWrapper);
    }

    function formatMoney(cents) {
        return (cents / 100).toLocaleString("de-DE", { style: "currency", currency: Shopify.currency.active });
    }
    const COLOR_OPTION_ALIASES = [
        "farbe",
        "color",
        "colour",
        "couleur",
        "colore",
        "kleur",
        "cor",
        "색상",
        "カラー",
        "цвет",
        "kolor",
        "culoare",
        "boja",
        "färg",
    ];
    function normalizeStr(s) {
        return (s || "").toString().trim().toLowerCase();
    }
    function isColorOptionName(name) {
        const n = normalizeStr(name);
        if (!n) return false;
        return COLOR_OPTION_ALIASES.some((alias) => n === alias || n.includes(alias));
    }
    function getBundleSelectedColorValue() {
        const variantIdInput = form.querySelector("input[name='id']");
        if (!variantIdInput || !variantIdInput.value) return "";
        const currentVariantId = parseInt(variantIdInput.value, 10);
        if (!currentVariantId) return "";
        let colorIdx = -1;
        for (let i = 0; i < BUNDLE_OPTIONS.length; i++) {
            if (isColorOptionName(BUNDLE_OPTIONS[i])) {
                colorIdx = i;
                break;
            }
        }
        if (colorIdx === -1) return "";
        const v = BUNDLE_VARIANTS.find((x) => x.id === currentVariantId);
        if (!v) return "";
        const key = "option" + (colorIdx + 1);
        return v[key] || "";
    }
    let products = [];
    for (let handle of handles) {
        const res = await fetch(`/products/${handle}.js`);
        const product = await res.json();
        products.push(product);
    }
    const CUSTOM_OPTION_LABELS = {
        0: {
            0: config.dataset.product1Option1Label || "",
            1: config.dataset.product1Option2Label || "",
            2: config.dataset.product1Option3Label || "",
        },
        1: {
            0: config.dataset.product2Option1Label || "",
            1: config.dataset.product2Option2Label || "",
            2: config.dataset.product2Option3Label || "",
        },
    };
    const selectedOptions = {};
    function applyBundleColorToProducts() {
        const bundleColorRaw = getBundleSelectedColorValue();
        if (!bundleColorRaw) return;
        const parts = bundleColorRaw.split("/").map((p) => p.trim());
        products.forEach((product, index) => {
            let targetColor = parts.length > 1 ? parts[index] || parts[0] : parts[0];
            const normalizedTarget = normalizeStr(targetColor);
            let colorOptionIndex = -1;
            product.options.forEach((opt, idx) => {
                if (isColorOptionName(opt.name)) colorOptionIndex = idx;
            });
            if (colorOptionIndex === -1) return;
            const key = "option" + (colorOptionIndex + 1);
            const match = product.variants.find((v) => normalizeStr(v[key]) === normalizedTarget);
            if (match) {
                selectedOptions[product.id][key] = match[key];
            }
        });
    }
    products.forEach((product) => {
        const block = document.createElement("div");
        block.className = "bundle-product-block";
        selectedOptions[product.id] = {};
        let visibleOptionIndex = 0;
        product.options.forEach((optionObj, optionIndex) => {
            const optionName = optionObj.name;
            const values = [...new Set(product.variants.map((v) => v["option" + (optionIndex + 1)]))];
            if (isColorOptionName(optionName)) {
                selectedOptions[product.id]["option" + (optionIndex + 1)] = values[0];
                return;
            }
            if (values.length <= 1) {
                selectedOptions[product.id]["option" + (optionIndex + 1)] = values[0];
                return;
            }
            const optionWrapper = document.createElement("div");
            const optionTitle = document.createElement("div");
            optionTitle.className = "bundle-option-title";
            const customLabel = CUSTOM_OPTION_LABELS[products.indexOf(product)]?.[visibleOptionIndex];
            optionTitle.textContent = customLabel && customLabel.trim() !== "" ? customLabel : optionName;
            const variantContainer = document.createElement("div");
            variantContainer.className = "bundle-variants";
            values.forEach((value, index) => {
                const btn = document.createElement("button");
                btn.type = "button";
                btn.className = "bundle-variant-btn";
                btn.textContent = value;
                if (index === 0) {
                    btn.classList.add("active");
                    selectedOptions[product.id]["option" + (optionIndex + 1)] = value;
                }
                btn.addEventListener("click", function () {
                    variantContainer
                        .querySelectorAll(".bundle-variant-btn")
                        .forEach((b) => b.classList.remove("active"));
                    btn.classList.add("active");
                    selectedOptions[product.id]["option" + (optionIndex + 1)] = value;
                    calculateTotal();
                });
                variantContainer.appendChild(btn);
            });
            optionWrapper.appendChild(optionTitle);
            optionWrapper.appendChild(variantContainer);
            block.appendChild(optionWrapper);
            visibleOptionIndex++;
        });
        bundleWrapper.appendChild(block);
    });
    function getSelectedVariant(product) {
        const options = selectedOptions[product.id];
        return product.variants.find((variant) => {
            return product.options.every((_, index) => {
                const key = "option" + (index + 1);
                return variant[key] === options[key];
            });
        });
    }
    function updateDisplayedPrice(newPriceCents) {
        const formatted = formatMoney(newPriceCents);
        const selectors = [
            "[data-product-price]",
            ".price",
            ".price-list.price-list--lg",
            ".product__price",
            ".price-item--regular",
            ".price__regular",
            ".product-price",
        ];
        selectors.forEach((selector) => {
            document.querySelectorAll(selector).forEach((el) => {
                el.innerHTML = formatted;
            });
        });
    }
    function calculateTotal() {
        if (showBundleProductPrice) return;
        let total = 0;
        products.forEach((product) => {
            const variant = getSelectedVariant(product);
            if (variant) total += variant.price;
        });
        if (discountValue > 0) {
            if (discountType === "percent") {
                total -= (total * discountValue) / 100;
            } else {
                total -= discountValue * 100;
            }
        }
        if (total < 0) total = 0;
        updateDisplayedPrice(total);
    }
    applyBundleColorToProducts();
    calculateTotal();
    form.addEventListener("change", function () {
        applyBundleColorToProducts();
        calculateTotal();
    });
    const variantIdInput = form.querySelector("input[name='id']");
    if (variantIdInput) {
        const mo = new MutationObserver(function () {
            applyBundleColorToProducts();
            calculateTotal();
        });
        mo.observe(variantIdInput, { attributes: true, attributeFilter: ["value"] });
        variantIdInput.addEventListener("change", function () {
            applyBundleColorToProducts();
            calculateTotal();
        });
    }
    function getBundleProperties() {
        const propertyInputs = form.querySelectorAll("input[name^='properties[']");
        const props = {};
        propertyInputs.forEach((input) => {
            const match = input.name.match(/properties\[(.*?)\]/);
            if (match && match[1]) {
                props[match[1]] = input.value;
            }
        });
        return props;
    }
    function openCartDrawer() {
        const cd = document.querySelector("cart-drawer");
        if (cd) {
            if (typeof cd.open === "function") {
                cd.open();
                return true;
            }
            cd.classList.add("active", "is-open");
            cd.removeAttribute("hidden");
            const overlay = cd.querySelector(".overlay") || cd.querySelector("[data-overlay]");
            if (overlay) overlay.removeAttribute("hidden");
            document.body.classList.add("overflow-hidden");
            return true;
        }
        const cn = document.querySelector("cart-notification");
        if (cn) {
            cn.classList.add("active", "is-open");
            cn.removeAttribute("hidden");
            return true;
        }
        const sidebar = document.querySelector(
            "[data-cart-sidebar],[data-mini-cart],[data-cart-drawer],.cart-drawer,.mini-cart,.side-cart,.js-cart-drawer"
        );
        if (sidebar) {
            sidebar.classList.add("active", "is-open", "open", "visible");
            sidebar.removeAttribute("hidden");
            sidebar.style.display = "";
            document.body.classList.add("overflow-hidden", "cart-open", "js-cart-open");
            return true;
        }
        const cartBtn = document.querySelector(
            "a[href='/cart'].header__icon,button[data-cart-toggle],.js-cart-toggle,.cart-icon-bubble,[data-cart-trigger]"
        );
        if (cartBtn) {
            cartBtn.click();
            return true;
        }
        document.dispatchEvent(new CustomEvent("cart:refresh"));
        document.dispatchEvent(new CustomEvent("theme:cart:toggle"));
        return false;
    }
    function updateCartCount() {
        fetch("/cart.js")
            .then((r) => r.json())
            .then((cart) => {
                document
                    .querySelectorAll(
                        ".cart-count-bubble span,.cart-count,[data-cart-count],.cart-item-count,.js-cart-count"
                    )
                    .forEach((el) => {
                        el.textContent = cart.item_count;
                        if (el.closest("[hidden]")) el.closest("[hidden]").removeAttribute("hidden");
                    });
                const cartIcon = document.querySelector(
                    ".cart-icon-bubble,[data-cart-icon],.header__icon--cart,.cart-count-bubble"
                );
                if (cartIcon) {
                    cartIcon.style.transform = "scale(1.3)";
                    setTimeout(() => {
                        cartIcon.style.transform = "";
                    }, 300);
                }
            })
            .catch(() => {});
    }

    // ── Impact Theme: _onSubmit auf der Instanz überschreiben ──────────────
    // Impact's ProductForm erweitert HTMLFormElement direkt (is="product-form").
    // Der interne _onSubmit-Handler wird im Constructor registriert und läuft
    // deshalb immer VOR unserem Handler — selbst mit capture:true.
    // Lösung: Die Methode auf der Instanz direkt ersetzen, bevor sie feuern kann.
    if (typeof form._onSubmit === "function") {
        form._onSubmit = function (event) {
            event.preventDefault();
            event.stopImmediatePropagation();
            // handleBundleSubmit wird durch unseren capture-Listener unten ausgeführt
        };
    }
    // ────────────────────────────────────────────────────────────────────────

    let isAdding = false;
    async function handleBundleSubmit(e) {
        if (e && typeof e.preventDefault === "function") {
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
        }
        if (isAdding) return;
        isAdding = true;
        applyBundleColorToProducts();
        const variantInput = form.querySelector("input[name='id']");
        if (variantInput) variantInput.value = "";
        const bundleProps = getBundleProperties();
        const items = [];
        const bundleId = "bundle_" + Date.now() + "_" + Math.random().toString(36).substring(2, 8);
        const CROPPER_BASE = config.dataset.backendBaseUrl || "";
        const originalCustomizationImage = bundleProps["_customization_image"] || "";
        const encodedSrc = encodeURIComponent(originalCustomizationImage);
        products.forEach((product, index) => {
            const variant = getSelectedVariant(product);
            if (!variant) return;
            let properties = {};
            properties["_bundle_id"] = bundleId;
            properties["_is_bundle"] = "true";
            properties["_bundle_handle"] = config.dataset.productHandle || bundleProduct.handle || "";
            properties["_bundle_title"] = config.dataset.productTitle || bundleProduct.title || "";
            if (originalCustomizationImage) {
                const focus = index === 0 ? "left" : "right";
                properties["_customization_image"] = `${CROPPER_BASE}/crop?src=${encodedSrc}&focus=${focus}`;
            }
            if (index === 0) {
                if (bundleProps["_customization_id"]) {
                    properties["_customization_id"] = bundleProps["_customization_id"];
                }
               if (index === 0) {
    if (bundleProps["_customization_id"]) {
        properties["_customization_id"] = bundleProps["_customization_id"];
    }
    if (bundleProps["_tib_design_link_1"]) {
        properties["_tib_design_link_1"] = bundleProps["_tib_design_link_1"];
    }
}
if (index === 1) {
    if (bundleProps["_customization_id"]) {
        properties["_customization_id"] = bundleProps["_customization_id"];
    }
    // Wenn _tib_design_link_2 vorhanden → nehme _2, sonst fallback auf _1
    if (bundleProps["_tib_design_link_2"]) {
        properties["_tib_design_link_2"] = bundleProps["_tib_design_link_2"];
    } else if (bundleProps["_tib_design_link_1"]) {
        properties["_tib_design_link_1"] = bundleProps["_tib_design_link_1"];
    }
}
            items.push({ id: variant.id, quantity: 1, properties: properties });
        });
        if (items.length === 0) {
            isAdding = false;
            return;
        }
        try {
            const resp = await fetch("/cart/add.js", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ items }),
            });
            if (!resp.ok) {
                const txt = await resp.text();
                console.error("cart/add.js error:", resp.status, txt);
                isAdding = false;
                return;
            }
            const responseJson = await resp.json();

            if (afterAddToCart === "redirect") {
                window.location.replace("/cart");

                
            } else if (afterAddToCart === "drawer") {
                // ── Impact Theme: cart:change Event feuern ─────────────────────────
                // Impact öffnet den Drawer AUSSCHLIESSLICH über dieses Custom Event
                // auf document.documentElement. openCartDrawer() allein reicht nicht.
                try {
                    const cartContent = await (await fetch("/cart.js")).json();
                    cartContent["sections"] = responseJson["sections"] || {};

                    form.dispatchEvent(new CustomEvent("variant:add", {
                        bubbles: true,
                        detail: {
                            items: responseJson.hasOwnProperty("items") ? responseJson["items"] : [responseJson],
                            cart: cartContent,
                        },
                    }));

                    document.documentElement.dispatchEvent(new CustomEvent("cart:change", {
                        bubbles: true,
                        detail: {
                            baseEvent: "variant:add",
                            cart: cartContent,
                        },
                    }));
                } catch (_) {}
                // ──────────────────────────────────────────────────────────────────

                updateCartCount();
                setTimeout(() => {
                    openCartDrawer();
                }, 300);
                isAdding = false;

                
            } else {
                updateCartCount();
                isAdding = false;
            }
        } catch (error) {
            console.error("Add to cart error:", error);
            isAdding = false;
        }
    }

    // Capture-Phase: läuft vor Impacts Constructor-Listener
    form.addEventListener("submit", handleBundleSubmit, true);
}
document.addEventListener("DOMContentLoaded", initBundleEngine);
document.addEventListener("shopify:section:load", initBundleEngine);
document.addEventListener("shopify:section:select", initBundleEngine);
document.addEventListener("shopify:block:select", initBundleEngine);
