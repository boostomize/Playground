{% if section.settings.enable_section %}
{% assign s = section.settings %}

<style>
  :root {
    --tb-accent:    {{ s.accent_color    | default: '#FF6B00' }};
    --tb-accent-bg: {{ s.accent_bg_color | default: '#FFF8F2' }};
    --tb-btn-bg:    {{ s.button_color    | default: '#FF6B00' }};
    --tb-btn-text:  {{ s.button_text_color | default: '#ffffff' }};
    --tb-radius:    16px;
  }

  /* ── Overlay Backdrop ── */
  #tb-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.52);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    z-index: 99999;
    display: none; /* shown via JS openModal() */
    align-items: flex-end;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.28s ease;
    overscroll-behavior: none;
    touch-action: none;
  }
  @media (min-width: 640px) {
    #tb-overlay { align-items: center; padding: 24px; }
  }
  #tb-overlay.tb-open {
    display: flex;
    opacity: 1;
  }

  /* ── Modal ── */
  #tb-modal {
    background: #fff;
    width: 100%;
    max-width: 560px;
    max-height: 94vh;
    border-radius: 24px 24px 0 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 -4px 40px rgba(0,0,0,0.18);
    /* Mobile: slide up from bottom */
    transform: translateY(80px);
    opacity: 0;
    transition: transform 0.44s cubic-bezier(0.22, 1.1, 0.36, 1),
                opacity   0.30s ease;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    box-sizing: border-box;
  }
  @media (min-width: 640px) {
    #tb-modal {
      border-radius: 24px;
      max-height: 90vh;
      box-shadow: 0 24px 64px rgba(0,0,0,0.22);
      /* Desktop: subtle scale + rise */
      transform: translateY(20px) scale(0.96);
    }
  }
  #tb-modal, #tb-modal * { box-sizing: border-box; }
  #tb-overlay.tb-open #tb-modal {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  /* ── Header ── */
  .tb-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px 12px;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
  }
  .tb-header-left {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 800;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.6px;
  }
  .tb-header-icon-wrap {
    width: 28px; height: 28px;
    background: var(--tb-accent);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .tb-header-icon-wrap svg { width: 15px; height: 15px; fill: none; stroke: #fff; stroke-width: 2; }
  .tb-close-btn {
    width: 32px; height: 32px;
    border: none;
    background: #f2f2f2;
    border-radius: 50%;
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555;
    line-height: 1;
    padding: 0;
    transition: background 0.18s;
    flex-shrink: 0;
  }
  .tb-close-btn:hover { background: #e4e4e4; }

  /* ── Scrollable Body ── */
  .tb-modal-body {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 11px 13px 4px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    overscroll-behavior-y: contain; /* prevents scroll chaining to body on iOS/Android */
    touch-action: pan-y;            /* lets the modal body scroll but nothing else */
  }

  /* Re-allow vertical scrolling inside the modal itself */
  #tb-modal {
    touch-action: pan-y;
  }

  /* ── Success Banner ── */
  .tb-success-banner {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f6f6f6;
    border-radius: 10px;
    padding: 8px 12px;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 9px;
    color: #222;
    line-height: 1.35;
  }
  .tb-success-banner .tb-check {
    width: 20px; height: 20px;
    background: #22c55e;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .tb-success-banner .tb-check svg { width: 11px; height: 11px; fill: none; stroke: #fff; stroke-width: 2.5; }

  /* ── Shipping Progress ── */
  .tb-shipping-section {
    background: var(--tb-accent-bg);
    border: 1.5px solid rgba(255,107,0,0.15);
    border-radius: 14px;
    padding: 11px 14px;
    margin-bottom: 11px;
  }
  .tb-shipping-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .tb-shipping-texts { flex: 1; }
  .tb-shipping-headline {
    font-size: 14px;
    font-weight: 800;
    color: #111;
    margin-bottom: 2px;
  }
  .tb-shipping-detail {
    font-size: 12px;
    color: #555;
    line-height: 1.4;
  }
  .tb-shipping-detail strong { color: var(--tb-accent); font-weight: 800; }
  .tb-shipping-badge {
    flex-shrink: 0;
    background: var(--tb-accent);
    color: #fff;
    font-size: 9.5px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    padding: 5px 9px;
    border-radius: 10px;
    text-align: center;
    line-height: 1.35;
  }
  .tb-progress-wrap {
    display: none; /* progress bar removed */
  }
  .tb-progress-track,
  .tb-progress-fill,
  .tb-progress-labels,
  .tb-progress-current,
  .tb-progress-goal-label { display: none; }

  /* ── VAT text under price ── */
  .tb-vat-text {
    font-size: 10px;
    color: #bbb;
    margin-top: -2px;
    margin-bottom: 5px;
    line-height: 1;
  }

  /* ── Free Shipping Reached ── */
  .tb-shipping-free {
    display: flex;
    align-items: center;
    gap: 9px;
    background: #edfaee;
    border: 1.5px solid #86efac;
    border-radius: 14px;
    padding: 9px 14px;
    font-size: 13px;
    font-weight: 700;
    color: #15803d;
    margin-bottom: 11px;
  }

  /* ── Section Label & Heading ── */
  .tb-upsell-intro { margin-bottom: 10px; }
  .tb-section-label {
    font-size: 10.5px;
    font-weight: 900;
    color: var(--tb-accent);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-bottom: 3px;
  }
  .tb-upsell-heading {
    font-size: 19px;
    font-weight: 900;
    margin: 0 0 4px;
    line-height: 1.18;
    color: #111;
  }
  .tb-upsell-subtext {
    font-size: 12.5px;
    color: #777;
    margin: 0;
    line-height: 1.4;
  }

  /* ── Product Grid ── */
  .tb-product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 9px;
    margin-bottom: 10px;
  }

  /* ── Product Card ── */
  .tb-card {
    background: #fff;
    border: 1.5px solid #ebebeb;
    border-radius: 14px;
    padding: 8px 8px 10px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.18s, box-shadow 0.18s;
  }
  .tb-card:hover {
    border-color: #ddd;
    box-shadow: 0 3px 14px rgba(0,0,0,0.09);
  }

  /* ── Card Image ── */
  .tb-card-image-wrap {
    width: 100%;
    padding-top: 100%;
    border-radius: 10px;
    overflow: hidden;
    background: #f3f3f3;
    position: relative;
    margin-bottom: 8px;
    flex-shrink: 0;
  }
  .tb-card-image-wrap img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Skeleton ── */
  .tb-skeleton {
    position: absolute; inset: 0;
    background: linear-gradient(90deg, #efefef 25%, #e2e2e2 50%, #efefef 75%);
    background-size: 200% 100%;
    animation: tb-shimmer 1.5s infinite;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 7px;
    padding: 10px;
  }
  @keyframes tb-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  .tb-skeleton-emoji { font-size: 22px; opacity: 0.5; animation: tb-pulse 1.5s ease-in-out infinite; }
  @keyframes tb-pulse {
    0%, 100% { opacity: 0.35; transform: scale(1); }
    50%       { opacity: 0.65; transform: scale(1.08); }
  }
  .tb-skeleton-text {
    font-size: 9.5px;
    font-weight: 700;
    color: #bbb;
    text-align: center;
    line-height: 1.35;
    max-width: 80px;
  }

  /* ── Card Badge ── */
  .tb-card-badge {
    position: absolute;
    top: 7px; left: 7px;
    background: var(--tb-accent);
    color: #fff;
    font-size: 9.5px;
    font-weight: 900;
    padding: 3px 8px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    z-index: 2;
  }

  /* ── Card Text ── */
  .tb-card-title {
    font-size: 13px;
    font-weight: 800;
    margin-bottom: 2px;
    line-height: 1.2;
    color: #111;
  }
  .tb-card-subtitle {
    font-size: 11px;
    color: #999;
    margin-bottom: 6px;
    line-height: 1.3;
  }
  .tb-card-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 6px;
    margin-top: auto;
  }
  .tb-card-price {
    font-size: 15px;
    font-weight: 800;
    color: #111;
  }
  .tb-card-price.tb-discount { color: #dc2626; }
  .tb-card-compare {
    font-size: 12px;
    color: #bbb;
    text-decoration: line-through;
  }

  /* ── Size Select ── */
  .tb-size-row { margin-bottom: 6px; }
  .tb-size-label { font-size: 10.5px; font-weight: 700; color: #666; margin-bottom: 3px; }
  .tb-size-select {
    width: 100%;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    padding: 5px 8px;
    font-size: 12px;
    background: #fff;
    cursor: pointer;
    appearance: auto;
  }
  .tb-size-select:focus { outline: 2px solid var(--tb-accent); border-color: transparent; }

  /* ── Add Button ── */
  .tb-add-btn {
    width: 100%;
    background: var(--tb-btn-bg);
    color: var(--tb-btn-text);
    border: none;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 4px;
    transition: opacity 0.18s, transform 0.1s;
    line-height: 1;
  }
  .tb-add-btn:hover  { opacity: 0.88; }
  .tb-add-btn:active { transform: scale(0.96); }
  .tb-add-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .tb-add-btn svg { width: 13px; height: 13px; flex-shrink: 0; fill: none; stroke: currentColor; stroke-width: 2.2; }

  /* ── Added Label ── */
  .tb-added-label {
    width: 100%;
    background: #dcfce7;
    border-radius: 999px;
    text-align: center;
    padding: 8px;
    font-size: 12.5px;
    font-weight: 800;
    color: #16a34a;
    margin-top: 4px;
    transition: opacity 0.35s ease;
  }
  .tb-added-label.tb-fadeout { opacity: 0; }

  /* ── Tip Box ── */
  .tb-tip-box {
    background: #fafafa;
    border: 1.5px solid #ebebeb;
    border-radius: 12px;
    padding: 8px 12px;
    font-size: 12px;
    color: #666;
    margin-bottom: 10px;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.4;
  }
  .tb-tip-box .tb-tip-icon { flex-shrink: 0; font-size: 15px; }

  /* ── Footer ── */
  .tb-modal-footer {
    padding: 10px 13px 12px;
    border-top: 1.5px solid #f0f0f0;
    flex-shrink: 0;
    background: #fff;
  }
  .tb-subtotal-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #111;
  }
  .tb-subtotal-row span:last-child { font-size: 16px; }
  .tb-checkout-btn {
    width: 100%;
    background: var(--tb-btn-bg);
    color: var(--tb-btn-text);
    border: none;
    border-radius: 999px;
    padding: 13px 20px;
    font-size: 16px;
    font-weight: 900;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 8px;
    transition: opacity 0.18s, transform 0.12s;
    letter-spacing: 0.2px;
  }
  .tb-checkout-btn:hover  { opacity: 0.9; }
  .tb-checkout-btn:active { transform: scale(0.98); }
  .tb-checkout-btn svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 2.2; }
  .tb-cart-link {
    display: block;
    text-align: center;
    font-size: 13px;
    color: #888;
    text-decoration: underline;
    cursor: pointer;
    transition: color 0.18s;
  }
  .tb-cart-link:hover { color: #444; }

  /* ── Skeleton shimmer bars (for text placeholders) ── */
  .tb-bar-skeleton {
    height: 11px;
    border-radius: 6px;
    background: linear-gradient(90deg, #efefef 25%, #e2e2e2 50%, #efefef 75%);
    background-size: 200% 100%;
    animation: tb-shimmer 1.5s infinite;
    margin-bottom: 5px;
  }

  /* ── Utility ── */
  .tb-hidden { display: none !important; }

  /* ── Floating Re-open Button ── */
  #tb-reopen-btn {
    position: fixed;
    z-index: 9998;
    {% if s.reopen_button_position == 'bottom-left' %}
    left: 16px;
    {% elsif s.reopen_button_position == 'bottom-center' %}
    left: 50%;
    {% else %}
    right: 16px;
    {% endif %}
    bottom: {{ s.reopen_button_bottom | default: 76 }}px;
    display: flex;
    align-items: center;
    gap: 9px;
    background: #fff;
    color: #111;
    border: 2px solid var(--tb-accent);
    border-radius: 999px;
    padding: 10px 16px 10px 12px;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 4px 18px rgba(0,0,0,0.14);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.32s ease, transform 0.36s cubic-bezier(0.22,1.1,0.36,1);
    transform: translateY(14px){% if s.reopen_button_position == 'bottom-center' %} translateX(-50%){% endif %};
    white-space: nowrap;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  #tb-reopen-btn.tb-reopen-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0){% if s.reopen_button_position == 'bottom-center' %} translateX(-50%){% endif %};
    animation: tb-reopen-float 3.5s ease-in-out 0.6s infinite;
  }
  @keyframes tb-reopen-float {
    0%, 100% { box-shadow: 0 4px 18px rgba(0,0,0,0.13); }
    50%       { box-shadow: 0 8px 28px rgba(0,0,0,0.18), 0 0 0 5px rgba(255,107,0,0.07); }
  }
  #tb-reopen-btn:hover  { background: var(--tb-accent-bg); box-shadow: 0 6px 24px rgba(0,0,0,0.2); }
  #tb-reopen-btn:active { opacity: 0.85; }
  /* Pulsing orange dot */
  .tb-reopen-dot {
    width: 8px; height: 8px;
    background: var(--tb-accent);
    border-radius: 50%;
    flex-shrink: 0;
    animation: tb-dot-pulse 2s ease-in-out infinite;
  }
  @keyframes tb-dot-pulse {
    0%, 100% { transform: scale(1);   opacity: 1;   }
    50%       { transform: scale(1.5); opacity: 0.6; }
  }
  #tb-reopen-btn svg { width: 14px; height: 14px; fill: none; stroke: var(--tb-accent); stroke-width: 2.5; flex-shrink: 0; }
  @media (min-width: 640px) {
    #tb-reopen-btn { bottom: {{ s.reopen_button_bottom_desktop | default: 24 }}px; }
  }

  /* ── Theme Editor Preview Button (nur im Editor sichtbar) ── */
  .tb-editor-trigger {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 99998;
    background: var(--tb-accent);
    color: #fff;
    border: 2px solid rgba(255,255,255,0.35);
    border-radius: 999px;
    padding: 11px 22px;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 6px 24px rgba(0,0,0,0.22);
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    transition: opacity 0.2s, transform 0.15s, background 0.2s;
    letter-spacing: 0.2px;
    white-space: nowrap;
  }
  .tb-editor-trigger:hover  { opacity: 0.9; transform: translateX(-50%) translateY(-2px); }
  .tb-editor-trigger:active { transform: translateX(-50%) scale(0.97); }
  .tb-editor-trigger.tb-editor-open {
    background: #222;
    border-color: rgba(255,255,255,0.15);
  }
  .tb-editor-label { font-size: 15px; }
  /* Editor-Infobanner am oberen Rand */
  .tb-editor-banner {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100000;
    background: #111;
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    padding: 7px 16px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    letter-spacing: 0.2px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .tb-editor-banner-dot {
    width: 7px; height: 7px;
    background: var(--tb-accent);
    border-radius: 50%;
    animation: tb-blink 1.2s ease-in-out infinite;
  }
  @keyframes tb-blink {
    0%, 100% { opacity: 1; } 50% { opacity: 0.3; }
  }
</style>

{% if request.design_mode %}
<div class="tb-editor-banner" id="tb-editor-banner" style="display:none">
  <span class="tb-editor-banner-dot"></span>
  Vorschaumodus – Änderungen werden live übernommen
</div>
<button class="tb-editor-trigger" id="tb-editor-trigger" aria-label="Popup Vorschau umschalten">
  <span class="tb-editor-label">👁</span> Popup Vorschau
</button>
{% endif %}

<div id="tb-overlay" role="dialog" aria-modal="true" aria-label="Upsell Angebote">
  <div id="tb-modal">

    <!-- Header -->
    <div class="tb-modal-header">
      <div class="tb-header-left">
        <div class="tb-header-icon-wrap">
          <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        </div>
        <span id="tb-item-count-text">Warenkorb</span>
      </div>
      <button class="tb-close-btn" id="tb-close-btn" aria-label="Schließen">✕</button>
    </div>

    <!-- Scrollable Body -->
    <div class="tb-modal-body">

      <!-- Success Banner – always in DOM; JS/schema controls visibility -->
      <div class="tb-success-banner" id="tb-success-banner"{% if s.show_success_banner == false %} style="display:none"{% endif %}>
        <span class="tb-check">
          <svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
        </span>
        <span><span id="tb-product-name">Produkt</span> erfolgreich hinzugefügt</span>
      </div>

      <!-- Shipping Block – always in DOM; progress bar removed, just text info -->
      <div class="tb-shipping-section" id="tb-shipping-section"{% if s.show_shipping_block == false %} style="display:none"{% endif %}>
        <div class="tb-shipping-top">
          <div class="tb-shipping-texts">
            <div class="tb-shipping-headline">Fast geschafft! 🚀</div>
            <div class="tb-shipping-detail">
              Nur noch <strong id="tb-remaining-amount">–</strong> für kostenlosen Versand
            </div>
          </div>
        </div>
      </div>

      <!-- Free Shipping Reached Banner – always in DOM -->
      <div class="tb-shipping-free tb-hidden" id="tb-shipping-free"{% if s.show_shipping_block == false %} style="display:none"{% endif %}>
        🎉 <span id="tb-free-shipping-text">Kostenloser Versand gesichert! Füge gerne weitere Produkte hinzu.</span>
      </div>

      <!-- Upsell Intro -->
      {% unless s.section_label == blank and s.heading_text == blank and s.subtext_text == blank %}
      <div class="tb-upsell-intro">
        {% unless s.section_label == blank %}<div class="tb-section-label">{{ s.section_label }}</div>{% endunless %}
        {% unless s.heading_text == blank %}<h2 class="tb-upsell-heading">{{ s.heading_text }}</h2>{% endunless %}
        {% unless s.subtext_text == blank %}<p class="tb-upsell-subtext">{{ s.subtext_text }}</p>{% endunless %}
      </div>
      {% endunless %}

      <!-- Product Grid (populated by JS) -->
      <div class="tb-product-grid" id="tb-product-grid"></div>

      <!-- Tip Box -->
      <div class="tb-tip-box" id="tb-tip-box">
        <span class="tb-tip-icon">🎁</span>
        <span>{{ s.tip_text | default: 'Viele Kunden bestellen gerne gleich ein passendes Extra dazu!' }}</span>
      </div>

    </div><!-- /.tb-modal-body -->

    <!-- Sticky Footer -->
    <div class="tb-modal-footer">
      <div class="tb-subtotal-row">
        <span>Zwischensumme</span>
        <span id="tb-subtotal">–</span>
      </div>
      <button class="tb-checkout-btn" id="tb-checkout-btn">
        {{ s.checkout_btn_text | default: 'Zur Kasse gehen' }}
        <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
      <a class="tb-cart-link" id="tb-cart-link">{{ s.back_link_text | default: 'Nein danke, nur zum Warenkorb' }}</a>
    </div>

  </div><!-- /#tb-modal -->
</div><!-- /#tb-overlay -->

{% if s.show_reopen_button != false %}
<button id="tb-reopen-btn" aria-label="{{ s.reopen_button_text | default: 'Dein Design auf mehr Produkten' }}">
  <span class="tb-reopen-dot"></span>
  {{ s.reopen_button_text | default: 'Dein Design auf mehr Produkten' }}
  <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
</button>
{% endif %}

<script>
/* ── Dawn / cart_type:page shim ──────────────────────────────────────────────
   In Dawn with cart_type="page" there is no <cart-notification> or
   <cart-drawer> in the DOM. Dawn's product-form.js checks:
     this.cart = querySelector('cart-notification') || querySelector('cart-drawer')
   If both are null it redirects to /cart — our popup never fires.

   Fix: inject a lightweight <cart-notification> element BEFORE Dawn's
   deferred scripts run (our <script> tag is synchronous, theirs are defer).
   Dawn finds our shim, skips the redirect, and calls renderContents() on it.
   We intercept renderContents() to trigger the upsell popup.

   Safe for other themes/cart types: only injected when no real element exists.
────────────────────────────────────────────────────────────────────────────── */
(function () {
  /* Only inject if no real cart element is present */
  if (document.querySelector('cart-notification') || document.querySelector('cart-drawer')) return;

  var shim = document.createElement('cart-notification');
  shim.id    = 'tb-cart-shim';
  shim.style.display = 'none';
  document.body.appendChild(shim);

  /* Methods expected by Dawn's product-form.js ─ defined as OWN properties
     so they survive the later prototype upgrade by cart-notification.js     */
  shim.getSectionsToRender = function () { return []; };
  shim.setActiveElement    = function () {};
  shim.renderContents      = function (parsedState) {
    /* parsedState = cart/add.js response for the newly added item */
    if (typeof window.__tbHandleCartAdd === 'function') {
      window.__tbHandleCartAdd(parsedState);
    }
  };
})();
</script>

<script>
(function () {
  /* ── Config from Schema ── */
  const CFG = {
    freeThreshold    : {{ s.free_shipping_threshold | default: 60 }} * 100,
    loadingText      : {{ s.loading_text | default: 'Wir erstellen dein Produkt…' | json }},
    popularBadge     : {{ s.popular_badge_text | default: 'Beliebt' | json }},
    popupDelay       : {{ s.popup_delay_ms | default: 120 }},
    freeShipText     : {{ s.free_shipping_reached_text | default: 'Kostenloser Versand gesichert! Füge gerne weitere Produkte hinzu.' | json }},
    showShipping     : {{ s.show_shipping_block | default: true }},
    showSuccessBanner: {{ s.show_success_banner | default: true }},
    vatText          : {{ s.vat_text | default: 'inkl. MwSt.' | json }},
    backendBase      : "https://upsell-design-extractor-transparent-production.up.railway.app"
  };

  /* ── Campaigns from Metafield ── */
  let CAMPAIGNS = [];
  try {
    const raw = {{ shop.metafields.boostomize.upsell_campaigns.value | json }};
    CAMPAIGNS = Array.isArray(raw) ? raw : JSON.parse(raw);
  } catch (e) { CAMPAIGNS = []; }

  /* ── Session (in-memory, survives bfcache back navigation) ── */
  let pageSession = null; // { mainItem, campaign, artworkUrl, handle }

  /* ── DOM Refs ── */
  const $ = id => document.getElementById(id);
  const overlay         = $("tb-overlay");
  const closeBtn        = $("tb-close-btn");
  const grid            = $("tb-product-grid");
  const subtotalEl      = $("tb-subtotal");
  const shippingSection = $("tb-shipping-section");
  const shippingFree    = $("tb-shipping-free");
  const freeShipTextEl  = $("tb-free-shipping-text");
  const remainingEl     = $("tb-remaining-amount");
  const itemCountText   = $("tb-item-count-text");
  const productNameEl   = $("tb-product-name");
  const checkoutBtn     = $("tb-checkout-btn");
  const cartLink        = $("tb-cart-link");
  const reopenBtn       = $("tb-reopen-btn");

  /* ── Helpers ── */
  const fmt  = c  => (c / 100).toFixed(2).replace(".", ",") + "\u00a0€";
  const wait = ms => new Promise(r => setTimeout(r, ms));

  function isProductPage() {
    return document.body.classList.contains("template-product");
  }

  async function fetchCart() {
    const r = await fetch("/cart.js", { credentials: "same-origin" });
    if (!r.ok) throw new Error("cart.js " + r.status);
    return r.json();
  }

  /* ── Re-open Button ── */
  function showReopenButton() {
    if (!reopenBtn || !pageSession) return;
    /* Only show on the same page URL where the popup originally opened */
    const currentUrl = window.location.href.split("?")[0];
    if (pageSession.url && pageSession.url !== currentUrl) return;
    reopenBtn.classList.add("tb-reopen-visible");
  }

  function hideReopenButton() {
    reopenBtn?.classList.remove("tb-reopen-visible");
  }

  /* ── iOS-safe scroll lock ───────────────────────────────────────────────
     On iOS Safari, overflow:hidden on <body> does NOT prevent page scrolling.
     The fix: temporarily position the body as fixed (saves scroll position
     so the page doesn't jump to top) and restore it on close.
  ──────────────────────────────────────────────────────────────────────── */
  let _savedScrollY = 0;

  function lockScroll() {
    _savedScrollY = window.scrollY;
    document.body.style.overflow   = "hidden";
    document.body.style.position   = "fixed";
    document.body.style.top        = `-${_savedScrollY}px`;
    document.body.style.width      = "100%";
  }

  function unlockScroll() {
    document.body.style.position = "";
    document.body.style.top      = "";
    document.body.style.width    = "";
    document.body.style.overflow = "";
    window.scrollTo(0, _savedScrollY);
  }

  function openModal() {
    overlay.classList.add("tb-open");
    lockScroll();
    hideReopenButton();
  }

  function closeModal() {
    overlay.classList.remove("tb-open");
    unlockScroll();
    if (pageSession) showReopenButton();
  }

  /* ── Update Summary Bar ── */
  async function updateSummary(cart) {
    if (!cart) { try { cart = await fetchCart(); } catch(e) { return; } }
    const total = cart.total_price || 0;
    const count = cart.item_count || 0;

    subtotalEl.textContent = fmt(total);
    itemCountText.textContent = count + (count === 1 ? " Artikel im Warenkorb" : " Artikel im Warenkorb");

    if (!CFG.showShipping) return;

    if (total >= CFG.freeThreshold) {
      shippingSection?.classList.add("tb-hidden");
      shippingFree?.classList.remove("tb-hidden");
      if (freeShipTextEl) freeShipTextEl.textContent = CFG.freeShipText;
    } else {
      shippingSection?.classList.remove("tb-hidden");
      shippingFree?.classList.add("tb-hidden");
      if (remainingEl) remainingEl.textContent = fmt(CFG.freeThreshold - total);
    }
  }

  /* ── Get Mockup Base URL from Storefront ── */
  function getBaseMockupUrl() {
    const img = document.querySelector(".tee-printarea--image img");
    return img ? img.src : null;
  }

  /* ── Build Preview URL ── */
  function buildPreviewUrl(endpoint, artworkUrl, baseMockupUrl, targetMockupUrl, pa) {
    const cacheKey = [artworkUrl, baseMockupUrl, targetMockupUrl, pa.x, pa.y, pa.width, pa.height].join("|");
    const p = new URLSearchParams({
      url: artworkUrl,
      mockup_url: baseMockupUrl,
      target_mockup_url: targetMockupUrl,
      print_x: pa.x, print_y: pa.y,
      print_w: pa.width, print_h: pa.height,
      cache_key: cacheKey
    });
    return CFG.backendBase + "/" + endpoint + "?" + p.toString();
  }

  /* ── Skeleton Cards (shown instantly) ── */
  function renderSkeletonCards(n) {
    grid.innerHTML = "";
    for (let i = 0; i < n; i++) {
      const card = document.createElement("div");
      card.className = "tb-card";
      /* Every other skeleton gets a fake size-select so height stays consistent */
      const hasFakeSelect = (i % 2 === 0);
      const selectHtml = hasFakeSelect ? `
        <div class="tb-size-row">
          <div class="tb-size-label" style="color:#ccc">Größe wählen</div>
          <select class="tb-size-select" disabled style="opacity:0.35;pointer-events:none">
            <option>S</option><option selected>M</option><option>L</option><option>XL</option>
          </select>
        </div>` : "";
      card.innerHTML = `
        <div class="tb-card-image-wrap">
          <div class="tb-skeleton">
            <span class="tb-skeleton-emoji">✨</span>
            <span class="tb-skeleton-text">${CFG.loadingText}</span>
          </div>
        </div>
        <div class="tb-bar-skeleton" style="width:72%"></div>
        <div class="tb-bar-skeleton" style="width:52%;margin-bottom:8px"></div>
        ${selectHtml}
        <div class="tb-bar-skeleton" style="width:48%;margin-bottom:6px"></div>
        <div class="tb-bar-skeleton" style="height:32px;border-radius:999px;margin-top:auto"></div>
      `;
      grid.appendChild(card);
    }
  }

  /* ── Find Campaign ── */
  async function findCampaign(handle) {
    if (!CAMPAIGNS.length) return null;
    let productData = null;
    try {
      const r = await fetch("/products/" + handle + ".js");
      if (r.ok) productData = await r.json();
    } catch (e) {}
    if (!productData) return null;
    const pid = String(productData.id);
    const specific = CAMPAIGNS.find(c => c.master_type === "product" && String(c.master_product_id) === pid);
    if (specific) return specific;
    return CAMPAIGNS.find(c => c.master_type === "collection") || null;
  }

  /* ── Render Real Product Cards ── */
  async function renderCards(campaign, mainItem, artworkUrl) {
    const baseMockupUrl = getBaseMockupUrl();
    grid.innerHTML = "";

    for (let ci = 0; ci < campaign.products.length; ci++) {
      const config = campaign.products[ci];
      let productData = null;
      if (config.product_handle) {
        try {
          const r = await fetch("/products/" + config.product_handle + ".js");
          if (r.ok) productData = await r.json();
        } catch (e) {}
      }

      const variants = productData ? productData.variants : [];

      /* Auto-detect size-type options */
      let visibleOptions = config.visible_options || [];
      if (visibleOptions.length === 0 && productData) {
        const sizeKws = ["größe", "groesse", "size", "taille", "maat"];
        visibleOptions = (productData.options || [])
          .filter(o => sizeKws.some(kw => o.name.toLowerCase().includes(kw)))
          .map(o => o.name);
      }
      const selectedOptions = {};

      /* ── Card ── */
      const card = document.createElement("div");
      card.className = "tb-card";

      /* Image wrap */
      const imageWrap = document.createElement("div");
      imageWrap.className = "tb-card-image-wrap";

      /* Badge on first card */
      if (ci === 0) {
        const badge = document.createElement("div");
        badge.className = "tb-card-badge";
        badge.textContent = CFG.popularBadge;
        imageWrap.appendChild(badge);
      }

      /* Skeleton loader */
      const skeleton = document.createElement("div");
      skeleton.className = "tb-skeleton";
      skeleton.innerHTML = `<span class="tb-skeleton-emoji">✨</span><span class="tb-skeleton-text">${CFG.loadingText}</span>`;
      imageWrap.appendChild(skeleton);

      /* Product image with backend preview */
      const img = document.createElement("img");
      img.alt = config.product_title || "";
      const previewState = { value: artworkUrl };

      if (baseMockupUrl && artworkUrl && config.mockup_url) {
        const pa = config.print_area || { x: 0.30, y: 0.28, width: 0.35, height: 0.40 };
        const urlMain     = buildPreviewUrl("generic-preview",     artworkUrl, baseMockupUrl, config.mockup_url, pa);
        const urlFallback = buildPreviewUrl("api/generic-preview", artworkUrl, baseMockupUrl, config.mockup_url, pa);

        fetch(urlMain)
  .then(r => r.json())
  .then(data => {
    if (data.ok && data.url) {
      previewState.value = data.url;
      img.onload  = function () { skeleton.style.display = "none"; };
      img.onerror = function () {
        previewState.value = artworkUrl;
        skeleton.style.display = "none";
        img.src = artworkUrl;
      };
      img.src = data.url;
    } else {
      throw new Error("no url");
    }
  })
  .catch(() => {
    previewState.value = artworkUrl;
    skeleton.style.display = "none";
    img.src = artworkUrl;
  });

      } else {
        previewState.value = artworkUrl;
        img.src = artworkUrl || "";
        img.onload = img.onerror = function () { skeleton.style.display = "none"; };
      }

      imageWrap.appendChild(img);
      card.appendChild(imageWrap);

      /* Title */
      const titleEl = document.createElement("div");
      titleEl.className = "tb-card-title";
      titleEl.textContent = config.product_title || (productData ? productData.title : "Produkt");
      card.appendChild(titleEl);

      /* Subtitle */
      const subtitleText = config.product_subtitle || (productData ? productData.product_type : "");
      if (subtitleText) {
        const subtitleEl = document.createElement("div");
        subtitleEl.className = "tb-card-subtitle";
        subtitleEl.textContent = subtitleText;
        card.appendChild(subtitleEl);
      }

      /* Size selects — collected first, appended after price */
      const sizeRowElements = [];
      for (const optName of visibleOptions) {
        if (!productData) continue;
        const optIndex = productData.options.findIndex(o => o.name === optName);
        if (optIndex < 0) continue;
        const optKey = "option" + (optIndex + 1);
        const values = [...new Set(variants.map(v => v[optKey]).filter(Boolean))];
        if (!values.length) continue;

        const sizeRow = document.createElement("div");
        sizeRow.className = "tb-size-row";
        const lbl = document.createElement("div");
        lbl.className = "tb-size-label";
        lbl.textContent = optName + " wählen";

        const sel = document.createElement("select");
        sel.className = "tb-size-select";
        values.forEach(val => {
          const opt = document.createElement("option");
          opt.value = opt.textContent = val;
          sel.appendChild(opt);
        });
        sel.value = values.includes("M") ? "M" : values[Math.floor(values.length / 2)];
        selectedOptions[optName] = sel.value;
        sel.addEventListener("change", e => { selectedOptions[optName] = e.target.value; });

        sizeRow.appendChild(lbl);
        sizeRow.appendChild(sel);
        sizeRowElements.push(sizeRow);
      }

      /* Price row */
      const priceRow = document.createElement("div");
      priceRow.className = "tb-card-price-row";
      const priceEl   = document.createElement("span");
      priceEl.className = "tb-card-price";
      priceEl.textContent = "–";
      const compareEl = document.createElement("span");
      compareEl.className = "tb-card-compare";
      priceRow.append(priceEl, compareEl);
      card.appendChild(priceRow);

      if (variants.length > 0) {
        const v0 = variants[0];
        const pc = parseInt(v0.price, 10);
        if (!isNaN(pc)) priceEl.textContent = fmt(pc);
        const cc = parseInt(v0.compare_at_price, 10);
        if (!isNaN(cc) && cc > pc) {
          compareEl.textContent = fmt(cc);
          priceEl.classList.add("tb-discount");
        }
      }

      /* VAT text */
      if (CFG.vatText) {
        const vatEl = document.createElement("div");
        vatEl.className = "tb-vat-text";
        vatEl.textContent = CFG.vatText;
        card.appendChild(vatEl);
      }

      /* Size selects – appended after price */
      sizeRowElements.forEach(row => card.appendChild(row));

      /* Add button */
      const addBtn = document.createElement("button");
      addBtn.className = "tb-add-btn";
      addBtn.innerHTML = `
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Hinzufügen`;
      card.appendChild(addBtn);

      /* Added label */
      const addedLbl = document.createElement("div");
      addedLbl.className = "tb-added-label tb-hidden";
      addedLbl.textContent = "✓ Hinzugefügt!";
      card.appendChild(addedLbl);

      /* Add-to-cart handler */
      addBtn.addEventListener("click", async () => {
        let variantId = null;
        if (variants.length) {
          if (!visibleOptions.length) {
            variantId = variants[0].id;
          } else {
            for (const v of variants) {
              let match = true;
              for (const oName of visibleOptions) {
                const oIdx = productData.options.findIndex(o => o.name === oName);
                if (oIdx < 0) continue;
                if (v["option" + (oIdx + 1)] !== selectedOptions[oName]) { match = false; break; }
              }
              if (match) { variantId = v.id; break; }
            }
            if (!variantId) variantId = variants[0].id;
          }
        }
        if (!variantId) return;

        const props = {};
        if (mainItem.properties) {
          if (mainItem.properties._customization_id)    props._customization_id = mainItem.properties._customization_id;
          if (mainItem.properties._tib_design_link_1)   props._tib_design_link_1 = mainItem.properties._tib_design_link_1;
          if (mainItem.properties._customization_image) props._original_customization_image = mainItem.properties._customization_image;
        }
        props._customization_image     = previewState.value || artworkUrl;
        props._upsell_id               = config.product_id || (productData ? String(productData.id) : "");
        props._upsell_product_title    = config.product_title || "";

        addBtn.disabled = true;
        try {
          const r = await fetch("/cart/add.js", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({ items: [{ id: variantId, quantity: 1, properties: props }] })
          });
          if (r.ok) {
            addBtn.classList.add("tb-hidden");
            addedLbl.classList.remove("tb-hidden");
            setTimeout(() => {
              addedLbl.classList.add("tb-fadeout");
              setTimeout(() => {
                addedLbl.classList.add("tb-hidden");
                addedLbl.classList.remove("tb-fadeout");
                addBtn.classList.remove("tb-hidden");
                addBtn.disabled = false;
              }, 380);
            }, 2200);
            await updateSummary();
          } else {
            addBtn.disabled = false;
          }
        } catch (e) {
          addBtn.disabled = false;
        }
      });

      grid.appendChild(card);
    }
  }

  /* ── Wait for Customization Item ── */
  async function waitForMainItem() {
    for (let i = 0; i < 22; i++) {
      try {
        const cart = await fetchCart();
        const item = cart.items.find(x =>
          x.properties &&
          typeof x.properties._customization_image === "string" &&
          x.properties._customization_image !== ""
        );
        if (item) return { item, cart };
      } catch (e) {}
      await wait(300);
    }
    return null;
  }

  /* ── Open Popup ── */
  /* sessionData: pass saved pageSession to skip waitForMainItem on re-open */
  async function openPopup(candidateHandle, sessionData) {
    const skeletonCount = sessionData?.campaign?.products?.length || 4;

    /* 1. Show modal immediately with skeletons */
    renderSkeletonCards(skeletonCount);
    openModal();

    let mainItem, cart, campaign;

    if (sessionData) {
      /* ── Re-open from session ── */
      mainItem = sessionData.mainItem;
      /* campaign may be null when restored from sessionStorage (not bfcache) */
      campaign = sessionData.campaign || await findCampaign(sessionData.handle);
      try { cart = await fetchCart(); } catch(e) {}
    } else {
      /* ── First open: wait for customization item ── */
      try { await updateSummary(); } catch (e) {}
      const result = await waitForMainItem();
      if (!result) { closeModal(); return; }
      mainItem = result.item;
      cart     = result.cart;
      campaign = await findCampaign(candidateHandle || mainItem.handle);
    }

    if (productNameEl) productNameEl.textContent = mainItem.product_title || mainItem.title || "Produkt";
    await updateSummary(cart);

    if (!campaign || !campaign.products?.length) { closeModal(); return; }

    await renderCards(campaign, mainItem, mainItem.properties._customization_image);

    /* 2. Save session — survives both bfcache and full-reload back navigation */
    const sessionUrl = window.location.href.split("?")[0];
    pageSession = { url: sessionUrl, mainItem, campaign, artworkUrl: mainItem.properties._customization_image, handle: candidateHandle || mainItem.handle };
    try {
      sessionStorage.setItem("tb_popup_session", JSON.stringify({
        url      : sessionUrl,
        handle   : pageSession.handle,
        artworkUrl: pageSession.artworkUrl,
        mainItem : {
          product_title: mainItem.product_title,
          title        : mainItem.title,
          handle       : mainItem.handle,
          properties   : mainItem.properties
        }
      }));
    } catch(e) {}
  }

  /* ── Cart Polling (drawer / notification themes) ── */
  let lastKeys = null;
  let running  = false;

  function isCartUIOpen() {
    const path = window.location.pathname;
    if (path === "/cart" || path.startsWith("/checkout")) return true;
    if (document.body.classList.contains("template-cart"))  return true;
    /* Dawn drawer (cart_type:drawer) */
    if (document.querySelector("cart-drawer.active"))        return true;
    /* Generic drawer fallback */
    if (document.querySelector(".cart-drawer.is-open"))      return true;
    /* Dawn notification (cart_type:notification) */
    if (document.querySelector("#cart-notification.active")) return true;
    /* Body overflow-hidden usually means a drawer/modal is open */
    if (document.body.classList.contains("overflow-hidden")) return true;
    return false;
  }

  async function hasPersonalisierbaTag(handle) {
    try {
      const r = await fetch("/products/" + handle + ".js");
      if (!r.ok) return false;
      const data = await r.json();
      const tags = Array.isArray(data.tags)
        ? data.tags.map(t => t.toLowerCase())
        : String(data.tags).split(",").map(t => t.trim().toLowerCase());
      return tags.includes("personalisierbar");
    } catch (e) { return false; }
  }

  async function checkCart() {
    if (running) return;
    running = true;
    try {
      const cart = await fetchCart();
      const keys = cart.items.map(i => i.key);

      if (lastKeys === null) { lastKeys = keys; running = false; return; }

      const newItems = cart.items.filter(i => !lastKeys.includes(i.key));
      lastKeys = keys;

      if (!newItems.length || isCartUIOpen()) { running = false; return; }

      const candidate = newItems[newItems.length - 1];
      if (await hasPersonalisierbaTag(candidate.handle)) {
        await wait(CFG.popupDelay);
        openPopup(candidate.handle);
      }
    } catch (e) {}
    running = false;
  }

  /* ── Dawn cart_type:page shim handler ──────────────────────────────────────
     Called by the <cart-notification> shim's renderContents() when Dawn's
     product-form.js fires after a successful add (instead of redirecting).
     parsedState = the raw cart/add.js response object for the added item.
  ────────────────────────────────────────────────────────────────────────── */
  window.__tbHandleCartAdd = async function (parsedState) {
    try {
      const handle = parsedState && (parsedState.handle || parsedState.product?.handle);
      if (!handle) return;
      if (!(await hasPersonalisierbaTag(handle))) return;
      await wait(CFG.popupDelay);
      openPopup(handle);
    } catch (e) {}
  };

  /* ── Dawn pubsub integration (cart_type:notification / drawer) ─────────────
     Subscribe to Dawn's internal 'cart-update' event as an extra trigger.
     Guards prevent double-opening: polling + pubsub both run but openPopup
     is async and the second caller will hit the already-open modal guard.
  ────────────────────────────────────────────────────────────────────────── */
  function trySubscribeDawnPubSub() {
    if (typeof subscribe !== "function" || typeof PUB_SUB_EVENTS === "undefined") return;
    subscribe(PUB_SUB_EVENTS.cartUpdate, async (event) => {
      if (event && event.source !== "product-form") return;
      if (isCartUIOpen()) return;
      if (overlay.classList.contains("tb-open")) return; // already open
      const handle = event && event.cartData && (event.cartData.handle || event.cartData.product?.handle);
      if (!handle) return;
      if (!(await hasPersonalisierbaTag(handle))) return;
      await wait(CFG.popupDelay);
      openPopup(handle);
    });
  }

  /* ── Init ── */
  document.addEventListener("DOMContentLoaded", () => {
    closeBtn.onclick = closeModal;
    overlay.onclick  = e => { if (e.target === overlay) closeModal(); };
    document.addEventListener("keydown", e => { if (e.key === "Escape") closeModal(); });

    checkoutBtn.onclick = () => { window.location.href = "/checkout"; };
    cartLink.onclick    = () => { window.location.href = "/cart"; };

    /* Re-open button */
    if (reopenBtn) {
      reopenBtn.onclick = () => {
        if (pageSession) openPopup(pageSession.handle, pageSession);
      };
    }

    /* Restore session from sessionStorage (for non-bfcache back navigation) */
    tryRestoreSession();

    /* Editor preview toggle button */
    const editorTrigger = $("tb-editor-trigger");
    const editorBanner  = $("tb-editor-banner");
    if (editorTrigger) {
      editorTrigger.onclick = () => {
        if (overlay.classList.contains("tb-open")) {
          closeModal();
          editorTrigger.classList.remove("tb-editor-open");
          editorTrigger.innerHTML = '<span class="tb-editor-label">👁</span> Popup Vorschau';
          if (editorBanner) editorBanner.style.display = "none";
        } else {
          showEditorPreview();
          editorTrigger.classList.add("tb-editor-open");
          editorTrigger.innerHTML = '<span class="tb-editor-label">✕</span> Vorschau schließen';
          if (editorBanner) editorBanner.style.display = "flex";
        }
      };
    }

    /* Start polling at 800ms interval (only outside design mode) */
    if (!window.Shopify || !Shopify.designMode) {
      setInterval(checkCart, 800);
      /* Also hook Dawn's own pub/sub for faster response (notification/drawer modes) */
      trySubscribeDawnPubSub();
    }
  });

  /* ── Restore session from sessionStorage ── */
  function tryRestoreSession() {
    try {
      const raw = sessionStorage.getItem("tb_popup_session");
      if (!raw) return;
      const data = JSON.parse(raw);
      const currentUrl = window.location.href.split("?")[0];
      if (!data.url || data.url !== currentUrl) return; // different page
      /* Reconstruct pageSession; campaign fetched lazily on re-open */
      pageSession = {
        url      : data.url,
        handle   : data.handle,
        mainItem : data.mainItem,
        artworkUrl: data.artworkUrl,
        campaign : null /* will be fetched via findCampaign() when re-opened */
      };
      showReopenButton();
    } catch(e) {}
  }

  /* ── Back-button / bfcache fix ──────────────────────────────────────────
     When the user navigates to /cart and presses the browser back button,
     the browser may restore this page from the back-forward cache (bfcache)
     WITH the overlay already visible.
     We use display:none on the overlay (set by JS) to prevent a flash,
     and pageshow cleans up any remaining state.
  ──────────────────────────────────────────────────────────────────────── */
  window.addEventListener("pageshow", (e) => {
    if (!e.persisted) return;

    /* 1. Ensure overlay is hidden (bfcache may have preserved .tb-open) */
    overlay.classList.remove("tb-open");
    unlockScroll();

    /* 2. Re-sync cart keys so the poller doesn't falsely re-trigger the popup */
    fetchCart().then(cart => {
      lastKeys = cart.items.map(i => i.key);
    }).catch(() => {});

    /* 3. pageSession is in memory (bfcache preserves it) – show reopen button */
    if (pageSession) showReopenButton();
  });

  /* ════════════════════════════════════════════════════
     THEME EDITOR PREVIEW
     Zeigt Demo-Daten im Shopify Customizer
  ════════════════════════════════════════════════════ */

  /** Baut eine Demo-Produktkarte mit Platzhalterbild */
  function buildDemoCard(title, subtitle, price, badge, sizes) {
    const card = document.createElement("div");
    card.className = "tb-card";

    const wrap = document.createElement("div");
    wrap.className = "tb-card-image-wrap";

    if (badge) {
      const b = document.createElement("div");
      b.className = "tb-card-badge";
      b.textContent = badge;
      wrap.appendChild(b);
    }

    /* Dezente, produkttypspezifische Hintergrundfarben */
    const bgColors = { "Tasse": "ede8e2", "Kissen": "e2e8e4", "Jutebeutel": "e8e6e2", "T-Shirt": "e4e4ec" };
    const bg = bgColors[title] || "ebebeb";
    const img = document.createElement("img");
    img.src = "https://placehold.co/300x300/" + bg + "/aaaaaa?text=" + encodeURIComponent(title);
    img.alt = title;
    img.style.cssText = "opacity:0;transition:opacity .35s";
    img.onload = function () { img.style.opacity = "1"; };
    wrap.appendChild(img);
    card.appendChild(wrap);

    const titleEl = document.createElement("div");
    titleEl.className = "tb-card-title";
    titleEl.textContent = title;
    card.appendChild(titleEl);

    if (subtitle) {
      const subEl = document.createElement("div");
      subEl.className = "tb-card-subtitle";
      subEl.textContent = subtitle;
      card.appendChild(subEl);
    }

    /* Price */
    const priceRow = document.createElement("div");
    priceRow.className = "tb-card-price-row";
    const priceEl = document.createElement("span");
    priceEl.className = "tb-card-price";
    priceEl.textContent = price;
    priceRow.appendChild(priceEl);
    card.appendChild(priceRow);

    /* VAT text */
    if (CFG.vatText) {
      const vatEl = document.createElement("div");
      vatEl.className = "tb-vat-text";
      vatEl.textContent = CFG.vatText;
      card.appendChild(vatEl);
    }

    /* Optional size select */
    if (sizes && sizes.length) {
      const sizeRow = document.createElement("div");
      sizeRow.className = "tb-size-row";
      const lbl = document.createElement("div");
      lbl.className = "tb-size-label";
      lbl.textContent = "Größe wählen";
      const sel = document.createElement("select");
      sel.className = "tb-size-select";
      sizes.forEach(s => {
        const opt = document.createElement("option");
        opt.value = opt.textContent = s;
        if (s === "M") opt.selected = true;
        sel.appendChild(opt);
      });
      sizeRow.appendChild(lbl);
      sizeRow.appendChild(sel);
      card.appendChild(sizeRow);
    }

    const addBtn = document.createElement("button");
    addBtn.className = "tb-add-btn";
    addBtn.innerHTML = '<svg viewBox="0 0 24 24" style="width:13px;height:13px;fill:none;stroke:currentColor;stroke-width:2.2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg> Hinzufügen';
    addBtn.onclick = e => { e.preventDefault(); }; // Kein Cart-Add im Preview
    card.appendChild(addBtn);

    return card;
  }

  /** Zeigt das Popup mit realistischen Demo-Daten */
  function showEditorPreview() {
    /* Demo-Produkte: letztes mit Größenauswahl */
    const demoProducts = [
      { title: "Tasse",      subtitle: "Keramik \u00b7 330 ml",            price: "14,95\u00a0\u20ac", badge: CFG.popularBadge, sizes: null },
      { title: "Kissen",     subtitle: "Weicher Bezug \u00b7 40\u00d740cm", price: "19,95\u00a0\u20ac", badge: null,             sizes: null },
      { title: "Jutebeutel", subtitle: "Robust & nachhaltig",               price: "14,95\u00a0\u20ac", badge: null,             sizes: null },
      { title: "T-Shirt",    subtitle: "100% Baumwolle \u00b7 Unisex",      price: "24,95\u00a0\u20ac", badge: null,             sizes: ["XS","S","M","L","XL","2XL"] }
    ];

    grid.innerHTML = "";
    demoProducts.forEach(p => grid.appendChild(buildDemoCard(p.title, p.subtitle, p.price, p.badge, p.sizes)));

    /* Header & Subtotal */
    if (productNameEl) productNameEl.textContent = "Muster Hoodie Weiß";
    itemCountText.textContent = "1 Artikel im Warenkorb";
    subtotalEl.textContent    = "39,95\u00a0\u20ac";

    /* Versand-Info (demo) – ohne Fortschrittsbalken */
    const demoTotal = 3995;

    if (CFG.showShipping) {
      if (demoTotal >= CFG.freeThreshold) {
        shippingSection?.classList.add("tb-hidden");
        shippingFree?.classList.remove("tb-hidden");
        if (freeShipTextEl) freeShipTextEl.textContent = CFG.freeShipText;
      } else {
        shippingSection?.classList.remove("tb-hidden");
        shippingFree?.classList.add("tb-hidden");
        if (remainingEl) remainingEl.textContent = fmt(CFG.freeThreshold - demoTotal);
      }
    }

    openModal();
  }

  /* ── Shopify Theme-Editor Section-Events ── */
  if (window.Shopify && Shopify.designMode) {
    const SID = "{{ section.id }}";

    /* Sektion im Editor angeklickt → Vorschau öffnen */
    document.addEventListener("shopify:section:select", e => {
      if (e.detail.sectionId !== SID) return;
      showEditorPreview();
      const t = $("tb-editor-trigger"), b = $("tb-editor-banner");
      if (t) { t.classList.add("tb-editor-open"); t.innerHTML = '<span class="tb-editor-label">\u2715</span> Vorschau schlie\u00dfen'; }
      if (b) b.style.display = "flex";
    });

    /* Sektion abgewählt → Vorschau schließen */
    document.addEventListener("shopify:section:deselect", e => {
      if (e.detail.sectionId !== SID) return;
      closeModal();
      const t = $("tb-editor-trigger"), b = $("tb-editor-banner");
      if (t) { t.classList.remove("tb-editor-open"); t.innerHTML = '<span class="tb-editor-label">\ud83d\udc41</span> Popup Vorschau'; }
      if (b) b.style.display = "none";
    });

    /* Einstellung geändert → Section wird neu gerendert → Vorschau direkt wieder öffnen */
    document.addEventListener("shopify:section:load", e => {
      if (e.detail.sectionId !== SID) return;
      /* Kurze Verzögerung damit das neue DOM bereit ist */
      setTimeout(() => {
        showEditorPreview();
        const t = $("tb-editor-trigger"), b = $("tb-editor-banner");
        if (t) { t.classList.add("tb-editor-open"); t.innerHTML = '<span class="tb-editor-label">\u2715</span> Vorschau schlie\u00dfen'; }
        if (b) b.style.display = "flex";
      }, 60);
    });
  }

})();
</script>

