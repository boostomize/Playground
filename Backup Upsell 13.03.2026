{% if section.settings.enable_section %}

<style>
  #tb-upsell-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 9999;
    display: none;
  }
  #tb-upsell-overlay.tb-upsell-visible { display: block; }

  .tb-upsell-modal {
    position: fixed; inset: 0;
    display: flex; flex-direction: column;
    font-family: inherit;
  }

  .tb-upsell-modal, .tb-upsell-modal * {
    box-sizing: border-box;
  }

  .tb-upsell-close-x {
    position: fixed;
    right: 14px; top: 10px;
    font-size: 28px;
    font-weight: 900;
    line-height: 1;
    cursor: pointer;
    z-index: 10000;
    color: #000;
  }

  .tb-upsell-top {
    flex: 1 1 auto;
    overflow-y: auto;
    background: #fff;
    padding: 12px 10px 220px;
  }
  @media(min-width:1100px){

  .tb-upsell-modal {
    justify-content: center;
    align-items: center;
  }

  .tb-upsell-top {
    width: 1200px;
    max-width: 92vw;
    margin: 40px auto 0 auto;
    padding: 30px 40px 260px;
    border-radius: 20px;
  }

  .tb-upsell-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .tb-upsell-footer-inner{
    width: 1200px;
    max-width: 92vw;
    margin: 0 auto;
  }

}

  .tb-upsell-box-success {
    background:#f4f4f4;
    border-radius:14px;
    padding:8px 10px;
    font-size:14px; font-weight:700;
    margin-bottom:10px;
  }
  .tb-upsell-box-free {
    display:flex; align-items:center; gap:8px;
    background:#daf8d0;
    border-radius:14px;
    padding:8px 10px;
    font-size:14px; font-weight:600;
    margin-bottom:14px;
  }
  .tb-hidden { display:none!important; }

  .tb-upsell-heading {
    font-size:22px; font-weight:900;
    margin-bottom:4px;
  }
  .tb-upsell-subtext { font-size:13px; margin-bottom:14px; }

  .tb-upsell-grid {
    display:grid;
    gap:10px;
    grid-template-columns:repeat(2, minmax(0, 1fr));
    width:100%;
  }
  @media(min-width:900px){
    .tb-upsell-grid { grid-template-columns:repeat(4, minmax(0, 1fr)); }
  }

  .tb-upsell-card {
    background:#fff;
    border-radius:14px;
    padding:8px 8px 12px;
    box-shadow:0 2px 8px rgba(0,0,0,0.08);
    display:flex; flex-direction:column;
    width:100%;
  }
  .tb-upsell-title {
    font-size:15px; font-weight:800;
    margin-bottom:4px;
  }

  .tb-upsell-image-wrap {
    width:100%; padding-top:100%;
    border-radius:10px; overflow:hidden;
    background:#f5f5f5; position:relative;
    margin-bottom:6px;
  }
  .tb-upsell-image-wrap img {
    position:absolute; inset:0;
    width:100%; height:100%; object-fit:cover;
  }
  .tb-upsell-image-skeleton {
    position:absolute; inset:0;
    background:linear-gradient(90deg,#eee,#dcdcdc,#eee);
    background-size:200% 100%;
    animation:tb-skeleton 1.2s linear infinite;
  }
  @keyframes tb-skeleton {
    0%{background-position:200% 0;}
    100%{background-position:-200% 0;}
  }

  /* Preisbereich */
  .tb-upsell-price-row {
    display:flex;
    flex-direction:column;
    align-items:flex-start;
    gap:2px;
    margin-bottom:6px;
  }
  .tb-upsell-price-line {
    display:flex;
    align-items:baseline;
    gap:4px;
  }
  .tb-upsell-price {
    font-size:15px;
    font-weight:800;
    color:#000;
  }
  .tb-upsell-price.tb-upsell-price--discount {
    color:#d32f2f;
  }
  .tb-upsell-compare-price {
    font-size:13px;
    color:#999;
    text-decoration:line-through;
  }
  .tb-upsell-tax {
    font-size:11px;
    color:#888;
  }

  /* Größe T-Shirts */
  .tb-upsell-size-row {
    display:flex;
    flex-direction:column;
    gap:4px;
    margin-bottom:6px;
    font-size:12px;
  }
  .tb-upsell-size-label {
    font-weight:600;
  }
  .tb-upsell-size-select {
    width:100%;
    border-radius:8px;
    border:1px solid #bfbfbf;
    padding:5px 8px;
    font-size:13px;
    background:#fff;
  }

  .tb-upsell-add-btn {
    width:100%;
    background:#ffb800; border:none;
    padding:7px 10px;
    border-radius:999px;
    font-weight:700; cursor:pointer;
    font-size:14px; color:#000;
    margin-top:6px;
  }

  .tb-upsell-added-label {
    width:100%;
    background:#e4f7e4;
    border-radius:999px;
    text-align:center;
    padding:7px;
    font-size:13px; font-weight:700;
    color:#138313;
    opacity:1;
    transition:opacity .35s ease, filter .35s ease;
    margin-top:6px;
  }
  .tb-upsell-added-label.tb-upsell-added-fadeout {
    opacity:0;
    filter:blur(3px);
  }

  .tb-upsell-footer {
    position:fixed; left:0; right:0; bottom:0;
    background:#fff;
    border-top:3px solid #f3c12c;
    padding:12px 12px 16px;
  }
  @media(min-width:900px){
    .tb-upsell-footer-inner{ max-width:900px; margin:0 auto; }
  }

  .tb-upsell-summary-row {
    display:flex; justify-content:space-between;
    align-items:center;
    margin-bottom:6px;
    font-size:14px;
    font-weight:700;
  }
  .tb-upsell-summary-subrow {
    display:flex; justify-content:space-between;
    align-items:center;
    font-size:12px;
    margin-bottom:10px;
  }

  .tb-upsell-footer-buttons {
    display:flex; gap:8px; margin-bottom:10px;
  }
  .tb-upsell-cart-btn {
    flex:1; background:#eee; border:none;
    padding:9px 10px; border-radius:999px;
    font-size:14px; font-weight:600;
    color: black;
    cursor:pointer;
  }
  .tb-upsell-checkout-btn {
    flex:1.2; background:#ffb800; border:none;
    color: black;
    padding:10px 12px; border-radius:999px;
    font-size:16px; font-weight:800; cursor:pointer;
  }

  .tb-upsell-back-link {
    padding-top:10px; text-align:center; font-size:13px;
  }
  .tb-upsell-back-link a { text-decoration:underline; cursor:pointer; }
</style>


<div id="tb-upsell-overlay">
  <div class="tb-upsell-modal">
    <div class="tb-upsell-close-x" id="tb-upsell-close-x">×</div>

    <div class="tb-upsell-top">
      <div class="tb-upsell-box-success">
        ✅ <span class="tb-upsell-product-name">Produktname</span> erfolgreich zum Warenkorb hinzugefügt
      </div>

      <div class="tb-upsell-box-free tb-hidden" id="tb-upsell-free-box">
        🚚 <span id="tb-upsell-free-text"></span>
      </div>

      <div class="tb-upsell-heading">Dein Design jetzt auch auf…</div>
      <div class="tb-upsell-subtext">
      </div>

      <div class="tb-upsell-grid">

        <!-- T-Shirt weiß -->
        {% if section.settings.show_tee_white %}
        <div
          class="tb-upsell-card"
          id="tb-upsell-card-tee-white"
          data-variant-id="56327450493303"
          data-endpoint="/tee-white-preview"
          data-size-xs="56327450427767"
          data-size-s="56327450460535"
          data-size-m="56327450493303"
          data-size-l="56327450526071"
          data-size-xl="56327450558839"
          data-size-xxl="56327450591607"
          data-size-3xl="56327450624375"
        >
          <div class="tb-upsell-title">T-Shirt weiß</div>
          <div class="tb-upsell-image-wrap">
            <div class="tb-upsell-image-skeleton"></div>
            <img src="" alt="T-Shirt weiß Vorschau">
          </div>
          <div class="tb-upsell-price-row">
            <div class="tb-upsell-price-line">
              <span class="tb-upsell-price">–</span>
              <span class="tb-upsell-compare-price"></span>
            </div>
            <div class="tb-upsell-tax">inkl. MwSt.</div>
          </div>

          <div class="tb-upsell-size-row">
            <span class="tb-upsell-size-label">Größe wählen</span>
            <select class="tb-upsell-size-select">
              <option value="XS">XS</option>
              <option value="S">S</option>
              <option value="M" selected>M</option>
              <option value="L">L</option>
              <option value="XL">XL</option>
              <option value="XXL">XXL</option>
              <option value="3XL">3XL</option>
            </select>
          </div>

          <button class="tb-upsell-add-btn">Hinzufügen</button>
