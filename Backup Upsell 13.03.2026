        </div>
        {% endif %}

        <!-- T-Shirt schwarz -->
        {% if section.settings.show_tee_black %}
        <div
          class="tb-upsell-card"
          id="tb-upsell-card-tee-black"
          data-variant-id="56327450198391"
          data-endpoint="/tee-black-preview"
          data-size-xs="56327450132855"
          data-size-s="56327450165623"
          data-size-m="56327450198391"
          data-size-l="56327450231159"
          data-size-xl="56327450263927"
          data-size-xxl="56327450296695"
          data-size-3xl="56327450329463"
        >
          <div class="tb-upsell-title">T-Shirt schwarz</div>
          <div class="tb-upsell-image-wrap">
            <div class="tb-upsell-image-skeleton"></div>
            <img src="" alt="T-Shirt schwarz Vorschau">
          </div>
          <div class="tb-upsell-price-row">
            <div class="tb-upsell-price-line">
              <span class="tb-upsell-price">–</span>
              <span class="tb-upsell-compare-price"></span>
            </div>
            <div class="tb-upsell-tax">inkl. MwSt.</div>
          </div>

          <div class="tb-upsell-size-row">
            <span class="tb-upsell-size-label">Größe wählen</span>
            <select class="tb-upsell-size-select">
              <option value="XS">XS</option>
              <option value="S">S</option>
              <option value="M" selected>M</option>
              <option value="L">L</option>
              <option value="XL">XL</option>
              <option value="XXL">XXL</option>
              <option value="3XL">3XL</option>
            </select>
          </div>

          <button class="tb-upsell-add-btn">Hinzufügen</button>
          <div class="tb-upsell-added-label tb-hidden">Erfolgreich hinzugefügt</div>
        </div>
      {% endif %}

        <!-- Tragetasche -->
        {% if section.settings.show_tote_natural %}
        <div
          class="tb-upsell-card"
          id="tb-upsell-card-tote"
          data-variant-id="56327280787831"
          data-endpoint="/tote-preview"
        >
          <div class="tb-upsell-title">Tragetasche natural</div>
          <div class="tb-upsell-image-wrap">
            <div class="tb-upsell-image-skeleton"></div>
            <img src="" alt="Tragetasche Vorschau">
          </div>
          <div class="tb-upsell-price-row">
            <div class="tb-upsell-price-line">
              <span class="tb-upsell-price">–</span>
              <span class="tb-upsell-compare-price"></span>
            </div>
            <div class="tb-upsell-tax">inkl. MwSt.</div>
          </div>

          <button class="tb-upsell-add-btn">Hinzufügen</button>
          <div class="tb-upsell-added-label tb-hidden">Erfolgreich hinzugefügt</div>
        </div>
      {% endif %}

        <!-- Tragetasche schwarz -->
        {% if section.settings.show_tote_black %}
        <div
          class="tb-upsell-card"
          id="tb-upsell-card-mug"
          data-variant-id="56327280755063"
          data-endpoint="/mug-preview"
        >
          <div class="tb-upsell-title">Tragetasche schwarz</div>
          <div class="tb-upsell-image-wrap">
            <div class="tb-upsell-image-skeleton"></div>
            <img src="" alt="Tragetasche schwarz Vorschau">
          </div>
          <div class="tb-upsell-price-row">
            <div class="tb-upsell-price-line">
              <span class="tb-upsell-price">–</span>
              <span class="tb-upsell-compare-price"></span>
            </div>
            <div class="tb-upsell-tax">inkl. MwSt.</div>
          </div>

          <button class="tb-upsell-add-btn">Hinzufügen</button>
          <div class="tb-upsell-added-label tb-hidden">Erfolgreich hinzugefügt</div>
        </div>
      {% endif %}

      </div>
    </div>

    <div class="tb-upsell-footer">
      <div class="tb-upsell-footer-inner">

        <div class="tb-upsell-summary-row">
          <span>Zwischensumme</span>
          <span id="tb-upsell-subtotal">0,00 €</span>
        </div>

        <div class="tb-upsell-summary-subrow">
          <span id="tb-upsell-delivery-window"></span>
          <span id="tb-upsell-shipping-amount"></span>
        </div>

        <div class="tb-upsell-footer-buttons">
          <button class="tb-upsell-cart-btn" id="tb-upsell-cart-btn">Warenkorb ansehen</button>
          <button class="tb-upsell-checkout-btn" id="tb-upsell-checkout-btn">Weiter zur Kasse</button>
        </div>

        <div class="tb-upsell-back-link">
          <a id="tb-upsell-back-link">Zurück und weiter shoppen</a>
        </div>

      </div>
    </div>

  </div>
</div>

<script>
(function(){

  const BACKEND_BASE = "https://upsell-design-extractor-transparent-production.up.railway.app";

  const FREE_SHIPPING_THRESHOLD = 6000;
  const SHIPPING_UNDER = 350;

  const overlay    = document.getElementById("tb-upsell-overlay");
  const closeX     = document.getElementById("tb-upsell-close-x");
  const freeBox    = document.getElementById("tb-upsell-free-box");
  const freeText   = document.getElementById("tb-upsell-free-text");
  const subtotalEl = document.getElementById("tb-upsell-subtotal");
  const shippingEl = document.getElementById("tb-upsell-shipping-amount");
  const deliveryEl = document.getElementById("tb-upsell-delivery-window");
  const cartBtn    = document.getElementById("tb-upsell-cart-btn");
  const checkoutBtn= document.getElementById("tb-upsell-checkout-btn");
  const backLink   = document.getElementById("tb-upsell-back-link");

  function money(c){ return (c/100).toFixed(2).replace(".",",")+" €"; }
  function delay(ms){ return new Promise(r=>setTimeout(r,ms)); }

  async function fetchCart(){
    const r = await fetch("/cart.js",{credentials:"same-origin"});
    if(!r.ok) throw new Error("cart.js "+r.status);
    return r.json();
  }

  async function initDynamicPrices(){
    const cards = document.querySelectorAll(".tb-upsell-card");
    for(const card of cards){
      const variantId = card.getAttribute("data-variant-id");
      const priceEl = card.querySelector(".tb-upsell-price");
      const compareEl = card.querySelector(".tb-upsell-compare-price");
      if(!variantId || !priceEl) continue;

      try{
        const r = await fetch(`/variants/${variantId}.js`, {credentials:"same-origin"});
        if(!r.ok) continue;
        const data = await r.json();
        const priceCents = parseInt(data.price, 10);
        const compareCents = data.compare_at_price ? parseInt(data.compare_at_price, 10) : NaN;

        if(!isNaN(priceCents)){
          priceEl.textContent = money(priceCents);
        }

        if(compareEl){
          if(!isNaN(compareCents) && compareCents > priceCents){
            compareEl.textContent = money(compareCents);
            priceEl.classList.add("tb-upsell-price--discount");
          } else {
            compareEl.textContent = "";
            priceEl.classList.remove("tb-upsell-price--discount");
          }
        }
      }catch(e){}
    }
  }

  function computeDeliveryWindow(){
    const t = new Date();
    const s = new Date(t); s.setDate(t.getDate()+3);
    const e = new Date(t); e.setDate(t.getDate()+4);

    const M = ["Jan","Feb","Mär","Apr","Mai","Jun","Jul","Aug","Sep","Okt","Nov","Dez"];
    const f = d => d.getDate().toString().padStart(2,"0")+"."+M[d.getMonth()];
    return "Lieferung zwischen "+f(s)+" und "+f(e);
  }

  async function updateSummary(){
    const cart = await fetchCart();
    const tot = cart.total_price || 0;
    subtotalEl.textContent = money(tot);
    deliveryEl.textContent = computeDeliveryWindow();

    if(tot >= FREE_SHIPPING_THRESHOLD){
      shippingEl.textContent = "Kostenlos";
      shippingEl.style.color = "#15a315";
      shippingEl.style.fontWeight = "700";
      freeBox.classList.add("tb-hidden");
    } else {
      shippingEl.textContent = money(SHIPPING_UNDER);
      freeBox.classList.remove("tb-hidden");
      const diff = FREE_SHIPPING_THRESHOLD - tot;
      freeText.textContent = "Noch "+money(diff)+" für kostenlosen Versand";
    }
  }

  function showAddedLabelTemporary(addBtn, addedLbl){
    addBtn.classList.add("tb-hidden");
    addedLbl.classList.remove("tb-hidden");
    addedLbl.classList.remove("tb-upsell-added-fadeout");

    setTimeout(()=>{
      addedLbl.classList.add("tb-upsell-added-fadeout");
      setTimeout(()=>{
        addedLbl.classList.add("tb-hidden");
        addedLbl.classList.remove("tb-upsell-added-fadeout");
        addBtn.classList.remove("tb-hidden");
      }, 400);
    }, 2000);
  }



function getBaseMockupUrl(){
  const img = document.querySelector(".tee-printarea--image img");
  if(img && img.src){
    return img.src;
  }
  return null;
}



  function setupUpsellCard(card, mainItem, artworkUrl){
    
console.log("SetupUpsellCard läuft");

const endpoint  = card.getAttribute("data-endpoint");
    const variantId = card.getAttribute("data-variant-id");
    const img       = card.querySelector("img");
    const skeleton  = card.querySelector(".tb-upsell-image-skeleton");
    const addBtn    = card.querySelector(".tb-upsell-add-btn");
    const addedLbl  = card.querySelector(".tb-upsell-added-label");

 const baseMockupUrl = getBaseMockupUrl();
if(!baseMockupUrl){
  console.error("Base Mockup URL nicht gefunden");
  return;
}
console.log("setupUpsellCard läuft");
console.log("BaseMockup:", baseMockupUrl);
console.log("Artwork:", artworkUrl);
const previewUrl =
  BACKEND_BASE + endpoint +
  "?url=" + encodeURIComponent(artworkUrl) +
  "&mockup_url=" + encodeURIComponent(baseMockupUrl) +
  "&cb=" + Date.now();

    /* CHANGE START: Handler vor src setzen + reset */
    skeleton.style.display = "";
    img.onload = null; img.onerror = null;
    img.removeAttribute("src");

    img.onload = ()=>{ skeleton.style.display="none"; };
    img.onerror = ()=>{ skeleton.style.display="none"; img.src = artworkUrl; };

    img.src = previewUrl;
    /* CHANGE END */

    addBtn.onclick = async ()=>{

      const qty = 1; // Menge fix 1

      const props = {...(mainItem.properties||{})};
      props._original_customization_image = artworkUrl;
      props._customization_image = previewUrl;
      if(mainItem.properties && mainItem.properties._customization_id){
      props._customization_id = mainItem.properties._customization_id;
      }

      addBtn.disabled = true;

      try{
        const r = await fetch("/cart/add.js",{
          method:"POST",
          headers:{"Content-Type":"application/json"},
          credentials:"same-origin",
          body:JSON.stringify({ items:[{ id:variantId, quantity:qty, properties:props }] })
        });

        if(!r.ok){
          addBtn.disabled = false;
          alert("Fehler beim Hinzufügen");
          return;
        }

        addBtn.disabled = false;
        showAddedLabelTemporary(addBtn, addedLbl);

        await updateSummary();

      }catch(e){
        addBtn.disabled = false;
        alert("Fehler");
      }
    };
  }

  function setupUpsellShirtCard(card, mainItem, artworkUrl){
    if(!card) return;

    const endpoint   = card.getAttribute("data-endpoint");
    const img        = card.querySelector("img");
    const skeleton   = card.querySelector(".tb-upsell-image-skeleton");
    const addBtn     = card.querySelector(".tb-upsell-add-btn");
    const addedLbl   = card.querySelector(".tb-upsell-added-label");
    const sizeSelect = card.querySelector(".tb-upsell-size-select");

   const baseMockupUrl = getBaseMockupUrl();
if(!baseMockupUrl){
  console.error("Base Mockup URL nicht gefunden");
  return;
}

const previewUrl =
  BACKEND_BASE + endpoint +
  "?url=" + encodeURIComponent(artworkUrl) +
  "&mockup_url=" + encodeURIComponent(baseMockupUrl) +
  "&cb=" + Date.now();

    /* CHANGE START: Handler vor src setzen + reset */
    skeleton.style.display = "";
    img.onload = null; img.onerror = null;
    img.removeAttribute("src");

    img.onload = ()=>{ skeleton.style.display="none"; };
    img.onerror = ()=>{ skeleton.style.display="none"; img.src = artworkUrl; };

    img.src = previewUrl;
    /* CHANGE END */

    if(sizeSelect && !sizeSelect.value){
      sizeSelect.value = "M";
    }

    function getVariantIdForSize(size){
      switch(size){
        case "XS": return card.dataset.sizeXs;
        case "S":  return card.dataset.sizeS;
        case "M":  return card.dataset.sizeM;
        case "L":  return card.dataset.sizeL;
        case "XL": return card.dataset.sizeXl;
        case "XXL":return card.dataset.sizeXxl;
        case "3XL":return card.dataset.size3xl;
        default: return null;
      }
    }

    addBtn.onclick = async ()=>{

      const qty = 1; // Menge fix 1
      const size = sizeSelect ? sizeSelect.value : "M";
      const variantId = getVariantIdForSize(size);

      if(!variantId){
        alert("Bitte eine Größe auswählen.");
        return;
      }

      const props = {...(mainItem.properties||{})};
      props._original_customization_image = artworkUrl;
      props._customization_image = previewUrl;
      if(mainItem.properties && mainItem.properties._customization_id){
      props._customization_id = mainItem.properties._customization_id;
      }

      addBtn.disabled = true;

      try{
        const r = await fetch("/cart/add.js",{
          method:"POST",
          headers:{"Content-Type":"application/json"},
          credentials:"same-origin",
          body:JSON.stringify({ items:[{ id:variantId, quantity:qty, properties:props }] })
        });

        if(!r.ok){
          addBtn.disabled = false;
          alert("Fehler beim Hinzufügen");
          return;
        }

        addBtn.disabled = false;
        showAddedLabelTemporary(addBtn, addedLbl);

        await updateSummary();

      }catch(e){
        addBtn.disabled = false;
        alert("Fehler");
      }
    };
  }

  async function waitForMainItem(){
    for(let i=0;i<20;i++){
      const cart = await fetchCart();
      const it = cart.items.find(x =>
        x.properties &&
        typeof x.properties._customization_image === "string" &&
        x.properties._customization_image !== ""
      );
      if(it) return it;
      await delay(300);
    }
    return null;
  }

  async function openPopup(mainItemCandidate){
    await delay(600);

    const mainItem = await waitForMainItem();
    if(!mainItem) return;

    document.querySelector(".tb-upsell-product-name").textContent =
      mainItem.product_title || mainItem.title || "Produkt";

    const artworkUrl = mainItem.properties._customization_image;

    const toteCard     = document.getElementById("tb-upsell-card-tote");
    const mugCard      = document.getElementById("tb-upsell-card-mug");
    const teeWhiteCard = document.getElementById("tb-upsell-card-tee-white");
    const teeBlackCard = document.getElementById("tb-upsell-card-tee-black");

    setupUpsellCard(toteCard, mainItem, artworkUrl);
    setupUpsellCard(mugCard,  mainItem, artworkUrl);
    setupUpsellShirtCard(teeWhiteCard, mainItem, artworkUrl);
    setupUpsellShirtCard(teeBlackCard, mainItem, artworkUrl);

    await updateSummary();

    overlay.classList.add("tb-upsell-visible");
  }

  function bindAddButton(){

    function isCartOpen(){
      if (window.location.pathname === "/cart") return true;
      if (document.body.classList.contains("template-cart")) return true;
      if (document.querySelector(".cart-drawer.is-open")) return true;
      return false;
    }

    let lastKeys = null;
    let running  = false;

    async function checkCart(){
      if(running) return;
      running = true;

      try{
        const cart = await fetchCart();
        const items = cart.items || [];
        const keys  = items.map(i=>i.key);

        if(lastKeys === null){
          lastKeys = keys;
          running = false;
          return;
        }

        const newItems = items.filter(i => !lastKeys.includes(i.key));

        lastKeys = keys;

        if(!newItems.length){
          running = false;
          return;
        }

        if(isCartOpen()){
          running = false;
          return;
        }

        const candidate = newItems[newItems.length - 1];

        let hasTag = false;
        try{
          if(candidate.handle){
            const r = await fetch(`/products/${candidate.handle}.js`);
            if(r.ok){
              const data = await r.json();
              const tags = Array.isArray(data.tags)
                ? data.tags.map(t=>t.toLowerCase())
                : (""+data.tags).split(",").map(t=>t.trim().toLowerCase());
              hasTag = tags.includes("personalisierbar");
            }
          }
        }catch(e){}

        if(!hasTag){
          running = false;
          return;
        }

        openPopup(candidate);

      }catch(e){}
      running = false;
    }

    setInterval(checkCart, 1200);
  }

  document.addEventListener("DOMContentLoaded", ()=>{
    bindAddButton();
    initDynamicPrices();

    closeX.onclick = ()=> overlay.classList.remove("tb-upsell-visible");
    backLink.onclick = ()=> overlay.classList.remove("tb-upsell-visible");
    cartBtn.onclick = ()=> window.location.href="/cart";
    checkoutBtn.onclick = ()=> window.location.href="/checkout";
  });

})();
</script>

{% endif %}

{% schema %}
{
  "name": "Upsell Popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Upsell Popup aktivieren",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tee_white",
      "label": "T-Shirt weiß anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tee_black",
      "label": "T-Shirt schwarz anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tote_natural",
      "label": "Tragetasche natural anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tote_black",
      "label": "Tragetasche schwarz anzeigen",
      "default": true
    }
  ],
  "presets": [
    { "name": "Upsell Popup" }
  ]
}
{% endschema %}
